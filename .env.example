APP_NAME="EcoDash"
APP_ENV=production
APP_KEY=base64:CI4wAzcuCj3cxZV1w+0WR9TChCuVKQniVS3RQcP3WX8=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Base de données ────────────────────────────────────────────
# Railway injecte automatiquement MYSQLHOST, MYSQLPORT, etc.
# quand vous ajoutez un service MySQL à votre projet
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST:-127.0.0.1}
DB_PORT=${MYSQLPORT:-3306}
DB_DATABASE=${MYSQLDATABASE:-ecodash}
DB_USERNAME=${MYSQLUSER:-root}
DB_PASSWORD=${MYSQLPASSWORD:-}

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

ADMIN_EMAIL=admin@ecodash.com
ADMIN_PASSWORD=Admin@2026!
